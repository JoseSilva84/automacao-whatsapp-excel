# auto, gemini ou openai.
AI_PROVIDER=gemini

# Gemini online. Crie uma chave no Google AI Studio.
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-3.5-flash

# OpenAI continua disponivel como alternativa, se quiser usar depois.
OPENAI_API_KEY=

# Nome do chat do WhatsApp onde voce salva mensagens para si mesmo.
# Em muitos celulares aparece como "Voce", "You" ou seu proprio nome.
WHATSAPP_SELF_CHAT_NAME=Voce

# Timezone usado para interpretar datas sem fuso explicito.
TIMEZONE=America/Fortaleza

# Google Calendar: use "primary" para o calendario principal.
GOOGLE_CALENDAR_ID=primary

# Google Sheets online. Se ficar vazio, a automacao grava apenas no arquivo Excel local.
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Agendamentos

# Arquivo Excel local gerado/atualizado automaticamente.
EXCEL_FILE=agendamentos.xlsx

# Se true, nao envia para Google Calendar/Sheets; apenas mostra o que seria feito.
DRY_RUN=false
